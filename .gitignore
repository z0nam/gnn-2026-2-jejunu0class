# LaTeX intermediates
*.aux
*.log
*.out
*.toc
*.nav
*.snm
*.fls
*.fdb_latexmk
*.synctex.gz
*.vrb
*.xdv

# Local scratch
scratch/*.txt

# OS/editor files
.DS_Store
Thumbs.db
.vscode/

# Avoid duplicate compiled PDFs in source folders
chapters/**/slides/*.pdf
chapters/**/notes/*.pdf

# Build directory artifacts (chapter-local)
chapters/**/build/*
!chapters/**/build/.gitkeep

# Google Docs link files
*.gdoc

# Reference source texts with copyright risk
references/books/*.pdf
references/books/*.epub
references/books/*.mobi

# Downloaded presentation PDFs from other students (copyright risk)
chapters/ch04_downloaded/
chapters/ch05-06/

# Auto-downloaded datasets from practice notebooks
practice/hands_on_gnn_examples/**/Cora/
practice/hands_on_gnn_examples/**/CiteSeer/
practice/hands_on_gnn_examples/**/PROTEINS/
practice/hands_on_gnn_examples/**/ml-100k/
practice/hands_on_gnn_examples/**/chameleon/
practice/hands_on_gnn_examples/**/wikipedia/
practice/hands_on_gnn_examples/**/data/

# Same datasets when they appear inside chapter folders
chapters/**/practice/Cora/
chapters/**/practice/CiteSeer/
chapters/**/practice/PROTEINS/
chapters/**/practice/ml-100k/
chapters/**/practice/chameleon/
chapters/**/practice/wikipedia/
chapters/**/practice/data/

# Python environments and caches
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Python version managers
.python-version
