# LaTeX intermediates
*.aux
*.log
*.out
*.toc
*.nav
*.snm
*.fls
*.fdb_latexmk
*.synctex.gz

# Local scratch
scratch/*.txt

# OS/editor files
.DS_Store
Thumbs.db
.vscode/

# Avoid duplicate compiled PDFs in source folders
chapters/**/slides/*.pdf
chapters/**/notes/*.pdf

# Build directory artifacts (chapter-local)
chapters/**/build/*
!chapters/**/build/.gitkeep

# Google Docs link files
*.gdoc

# Python environments and caches
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Python version managers
.python-version
